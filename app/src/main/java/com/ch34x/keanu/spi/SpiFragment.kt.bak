package com.ch34x.keanu.spi

import android.os.Bundle
import android.view.*
import android.widget.*
import androidx.fragment.app.Fragment
import com.ch34x.keanu.R

/*
SPI工具界面

*/

class SpiFragment : Fragment() {

private lateinit var detectBtn: Button
private lateinit var readBtn: Button
private lateinit var eraseBtn: Button

private lateinit var status: TextView

private lateinit var flash: SpiFlashManager

override fun onCreateView(
    inflater: LayoutInflater,
    container: ViewGroup?,
    savedInstanceState: Bundle?
): View {

    val v =
        inflater.inflate(R.layout.fragment_spi, container, false)

    detectBtn = v.findViewById(R.id.btn_detect)
    readBtn = v.findViewById(R.id.btn_read)
    eraseBtn = v.findViewById(R.id.btn_erase)

    status = v.findViewById(R.id.txt_status)

    detectBtn.setOnClickListener {

        detect()

    }

    readBtn.setOnClickListener {

        status.text = "读取Flash..."

    }

    eraseBtn.setOnClickListener {

        status.text = "擦除Flash..."

    }

    return v

}

private fun detect() {

    val chip = flash.detect()

    status.text =
        chip?.model ?: "未知Flash"

}

}