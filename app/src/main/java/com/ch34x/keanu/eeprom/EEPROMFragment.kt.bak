package com.ch34x.keanu.eeprom

import android.os.Bundle
import android.view.*
import android.widget.*
import androidx.fragment.app.Fragment
import com.ch34x.keanu.R

/*
 EEPROM界面
 ------------------------------------------------
 读取/写入/导入导出
 */
class EEPROMFragment : Fragment() {

    private lateinit var readBtn: Button
    private lateinit var writeBtn: Button
    private lateinit var statusView: TextView
    private lateinit var eepromManager: EEPROMManager

    override fun onCreateView(
        inflater: LayoutInflater,
        container: ViewGroup?,
        savedInstanceState: Bundle?
    ): View {
        val v = inflater.inflate(R.layout.fragment_eeprom, container, false)
        readBtn = v.findViewById(R.id.btn_eeprom_read)
        writeBtn = v.findViewById(R.id.btn_eeprom_write)
        statusView = v.findViewById(R.id.txt_eeprom_status)

        readBtn.setOnClickListener { read() }
        writeBtn.setOnClickListener { write() }
        return v
    }

    private fun read() {
        val data = eepromManager.read(0, 256)
        statusView.text = "读取: ${data.joinToString(" ") { "%02X".format(it) }}"
    }

    private fun write() {
        val data = ByteArray(4) { it.toByte() }
        eepromManager.write(0, data)
        statusView.text = "写入完成"
    }
}